<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CineFAST"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Items"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Snacks and Drinks"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_marginBottom="12dp"
                android:background="#333333">

                <ImageView
                    android:id="@+id/imgPopcorn"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@color/black"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtPopcornName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Popcorn"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtPopcornDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Large / Buttered"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtPopcornPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$8.99"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnPopcornMinus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="-"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/txtPopcornQty"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnPopcornPlus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="+"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_marginBottom="12dp"
                android:background="#333333">

                <ImageView
                    android:id="@+id/imgNachos"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@color/black"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtNachosName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nachos"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtNachosDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="With Cheese Dip"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtNachosPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$7.99"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnNachosMinus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="-"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/txtNachosQty"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnNachosPlus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="+"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_marginBottom="12dp"
                android:background="#333333">

                <ImageView
                    android:id="@+id/imgDrink"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@color/black"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtDrinkName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soft Drink"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDrinkDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Large / Any Flavor"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtDrinkPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$5.99"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnDrinkMinus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="-"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/txtDrinkQty"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnDrinkPlus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="+"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_marginBottom="12dp"
                android:background="#333333">

                <ImageView
                    android:id="@+id/imgCandy"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@color/black"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtCandyName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Candy Mix"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtCandyDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assorted Candies"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtCandyPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$6.99"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnCandyMinus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="-"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/txtCandyQty"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnCandyPlus"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="+"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:backgroundTint="@color/black"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm"
        android:textColor="@color/white"
        android:backgroundTint="@color/lightRed"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />
</LinearLayout>